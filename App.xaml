<Application x:Class="PersonalFinanceCategorizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BgColor" Color="#0F172A"/>
            <SolidColorBrush x:Key="CardColor" Color="#1E293B"/>
            <SolidColorBrush x:Key="PrimaryColor" Color="#6366F1"/>
            <SolidColorBrush x:Key="TextColor" Color="#F1F5F9"/>
            <SolidColorBrush x:Key="SubTextColor" Color="#94A3B8"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
