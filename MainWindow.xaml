<Window x:Class="PersonalFinanceCategorizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PersonalFinanceCategorizer.ViewModels"
        xmlns:helpers="clr-namespace:PersonalFinanceCategorizer.Helpers"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="Personal Finance Categorizer" Height="600" Width="1000"
        Background="{StaticResource BgColor}"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Foreground="White">
    
    <Window.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:ConfidenceToColorConverter x:Key="ConfToColor" />
        <helpers:CategoryToIconConverter x:Key="CatToIcon" />
        <helpers:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" Opacity="0.3" ShadowDepth="0" Color="Black"/>

        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" Opacity="0.3" ShadowDepth="0" Color="#6366F1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SubTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0,10,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,16" Padding="20,16">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Personal Finance Categorizer" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="AI-powered expense tracking" FontSize="13" Foreground="{StaticResource SubTextColor}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Upload CSV" Command="{Binding UploadCsvCommand}" Background="#334155"/>
                    <Button Content="Smart Categorization" Command="{Binding CategorizeAllCommand}" Margin="12,0,0,0" Background="{StaticResource PrimaryColor}"/>
                    <Button Content="Export CSV" Command="{Binding ExportCsvCommand}" Margin="12,0,0,0" Background="#059669"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Transactions List -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock Text="Transactions" DockPanel.Dock="Top" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Resources>
                            <Style TargetType="TextBlock" x:Key="WhiteText">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100" ElementStyle="{StaticResource WhiteText}"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" ElementStyle="{StaticResource WhiteText}"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="110" ElementStyle="{StaticResource WhiteText}"/>
                            <DataGridTemplateColumn Header="Category" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#334155" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Category, Converter={StaticResource CatToIcon}}" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Category}" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Confidence" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding ConfidenceScore, Converter={StaticResource ConfToColor}}" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ConfidenceScore, StringFormat=P0}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Insights & Charts -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="12,0,0,0">
                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Overview" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>
                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Total Spent" FontSize="11" Foreground="{StaticResource SubTextColor}"/>
                                    <TextBlock Text="{Binding TotalSpend}" FontSize="24" FontWeight="Bold" Foreground="#FB7185"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Top Category" FontSize="11" Foreground="{StaticResource SubTextColor}"/>
                                    <TextBlock Text="{Binding TopCategory}" FontSize="24" FontWeight="Bold" Foreground="#34D399"/>
                                </StackPanel>
                            </UniformGrid>
                            <Border Background="#0F172A" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="✨ Smart Insights" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AiInsights}" TextWrapping="Wrap" FontSize="13" LineHeight="20" FontStyle="Italic" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,24">
                        <lvc:PieChart Series="{Binding PieSeries}" Height="220"/>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}">
                        <lvc:CartesianChart Series="{Binding BarSeries}" Height="220"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Loader -->
        <Border Grid.RowSpan="2" Background="#CC0F172A" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Foreground="{StaticResource PrimaryColor}" Background="Transparent" BorderThickness="0"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,24,0,0" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
